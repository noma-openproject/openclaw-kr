{
  "name": "@openclaw/kakao-talkchannel",
  "version": "0.5.1",
  "description": "Kakao TalkChannel integration for OpenClaw",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "index.ts",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests index.ts",
    "typecheck": "tsc --noEmit"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "kakao-talkchannel",
      "label": "Kakao TalkChannel",
      "selectionLabel": "카카오톡 채널",
      "docsPath": "/channels/kakao-talkchannel",
      "docsLabel": "kakao-talkchannel",
      "blurb": "KakaoTalk 채널 챗봇을 OpenClaw에 연결합니다",
      "order": 80,
      "quickstartAllowFrom": false
    },
    "compatibility": {
      "testedWith": "2026.2.20"
    },
    "install": {
      "npmSpec": "@openclaw/kakao-talkchannel",
      "localPath": "extensions/kakao-talkchannel",
      "defaultChoice": "npm"
    }
  },
  "dependencies": {
    "zod": "^3.22.0",
    "zod-to-json-schema": "^3.25.1"
  },
  "peerDependencies": {
    "openclaw": ">=2026.1.29"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^9.21.0",
    "openclaw": "2026.2.24",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.24.1",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
